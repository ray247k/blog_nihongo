			<item>
				<title>助詞＋名詞</title>
				<link>https://nihongo.ray247k.com/docs/%E5%9F%BA%E7%A4%8E%E6%96%87%E6%B3%95/%E5%8A%A9%E8%A9%9E/%E5%8A%A9%E8%A9%9E%E5%90%8D%E8%A9%9E/</link>
				<pubDate>Mon, 01 Jan 0001 00:00:00 +0000</pubDate>
				<guid>https://nihongo.ray247k.com/docs/%E5%9F%BA%E7%A4%8E%E6%96%87%E6%B3%95/%E5%8A%A9%E8%A9%9E/%E5%8A%A9%E8%A9%9E%E5%90%8D%E8%A9%9E/</guid>
				<description>&lt;h1 id=&#34;と和&#34;&gt;と(和)&lt;a class=&#34;anchor&#34; href=&#34;#%e3%81%a8%e5%92%8c&#34;&gt;#&lt;/a&gt;&lt;/h1&gt;&#xD;&#xA;&lt;p&gt;用來連接名詞，屬於全部列舉&lt;/p&gt;&#xA;&lt;blockquote class=&#39;book-hint &#39;&gt;&#xD;&#xA;&lt;h2 id=&#34;名詞--と-名詞&#34;&gt;名詞 + と 名詞&lt;a class=&#34;anchor&#34; href=&#34;#%e5%90%8d%e8%a9%9e--%e3%81%a8-%e5%90%8d%e8%a9%9e&#34;&gt;#&lt;/a&gt;&lt;/h2&gt;&#xD;&#xA;&lt;/blockquote&gt;&lt;blockquote class=&#39;book-hint &#39;&gt;&#xD;&#xA;&lt;p&gt;&lt;span class=&#34;book-katex optional&#34; &gt;\( \overset{わたし}{私}\textcolor{blue}{と}\overset{いもうと}{妹}\textcolor{blue}{と}\overset{おとうと}{弟} \)&lt;/span&gt;&lt;link rel=&#34;stylesheet&#34; href=&#34;https://nihongo.ray247k.com/katex/katex.min.css&#34; /&gt;&lt;script defer src=&#34;https://nihongo.ray247k.com/katex/katex.min.js&#34;&gt;&lt;/script&gt;&lt;script defer src=&#34;https://nihongo.ray247k.com/katex/auto-render.min.js&#34; onload=&#34;renderMathInElement(document.body, {&amp;#34;delimiters&amp;#34;:[{&amp;#34;left&amp;#34;:&amp;#34;$$&amp;#34;,&amp;#34;right&amp;#34;:&amp;#34;$$&amp;#34;,&amp;#34;display&amp;#34;:true},{&amp;#34;left&amp;#34;:&amp;#34;\\(&amp;#34;,&amp;#34;right&amp;#34;:&amp;#34;\\)&amp;#34;,&amp;#34;display&amp;#34;:false},{&amp;#34;left&amp;#34;:&amp;#34;\\[&amp;#34;,&amp;#34;right&amp;#34;:&amp;#34;\\]&amp;#34;,&amp;#34;display&amp;#34;:true}]});&#34;&gt;&lt;/script&gt;（我和妹妹和弟弟）&lt;/p&gt;&#xA;&lt;/blockquote&gt;&lt;blockquote class=&#39;book-hint &#39;&gt;&#xD;&#xA;&lt;p&gt;&lt;span class=&#34;book-katex optional&#34; &gt;\( \overset{いぬ}{犬}\textcolor{blue}{と}\overset{ねこ}{猫} \)&lt;/span&gt;（狗和貓）&lt;/p&gt;&#xA;&lt;/blockquote&gt;&lt;blockquote class=&#39;book-hint &#39;&gt;&#xD;&#xA;&lt;p&gt;&lt;span class=&#34;book-katex optional&#34; &gt;\( \overset{うめ}{梅}\textcolor{blue}{と}\overset{さくら}{桜} \)&lt;/span&gt;  （梅花和櫻花）&lt;/p&gt;&#xA;&lt;/blockquote&gt;&lt;h1 id=&#34;やなど像是等等&#34;&gt;や&amp;hellip;など(像是&amp;hellip;等等)&lt;a class=&#34;anchor&#34; href=&#34;#%e3%82%84%e3%81%aa%e3%81%a9%e5%83%8f%e6%98%af%e7%ad%89%e7%ad%89&#34;&gt;#&lt;/a&gt;&lt;/h1&gt;&#xD;&#xA;&lt;p&gt;表示從眾多物品中選擇幾樣當作例子，屬於部分列舉&lt;/p&gt;&#xA;&lt;blockquote class=&#39;book-hint &#39;&gt;&#xD;&#xA;&lt;h2 id=&#34;名詞--や--名詞--など&#34;&gt;名詞 + や + 名詞 + など&lt;a class=&#34;anchor&#34; href=&#34;#%e5%90%8d%e8%a9%9e--%e3%82%84--%e5%90%8d%e8%a9%9e--%e3%81%aa%e3%81%a9&#34;&gt;#&lt;/a&gt;&lt;/h2&gt;&#xD;&#xA;&lt;/blockquote&gt;&lt;blockquote class=&#39;book-hint &#39;&gt;&#xD;&#xA;&lt;p&gt;&lt;span class=&#34;book-katex optional&#34; &gt;\( \overset{わ}{和}\overset{しょく}{食}と\overset{い}{言}えば、\overset{すし}{寿司}\textcolor{blue}{や}\overset{みそしる}{味噌汁}\textcolor{blue}{や}てんぷら\textcolor{blue}{など}です。 \)&lt;/span&gt;&lt;br&gt;&#xA;（說到和食，有壽司、味噌湯、天婦羅等等。）&lt;/p&gt;&#xA;&lt;/blockquote&gt;&lt;blockquote class=&#39;book-hint &#39;&gt;&#xD;&#xA;&lt;p&gt;&lt;span class=&#34;book-katex optional&#34; &gt;\( \overset{の}{飲}み\overset{もの}{物}と\overset{い}{言}えば、コーラ\textcolor{blue}{や}ジュース\textcolor{blue}{や}お\overset{ちゃ}{茶}\textcolor{blue}{など}です。 \)&lt;/span&gt;&lt;br&gt;&#xA;（說到飲料，有可樂、果汁、茶等等）&lt;/p&gt;&#xA;&lt;/blockquote&gt;&lt;h1 id=&#34;か或者&#34;&gt;か(或者)&lt;a class=&#34;anchor&#34; href=&#34;#%e3%81%8b%e6%88%96%e8%80%85&#34;&gt;#&lt;/a&gt;&lt;/h1&gt;&#xD;&#xA;&lt;p&gt;表示從名詞中擇一，屬於全部列舉&lt;/p&gt;&#xA;&lt;blockquote class=&#39;book-hint &#39;&gt;&#xD;&#xA;&lt;h2 id=&#34;名詞--か--名詞&#34;&gt;名詞 + か + 名詞&lt;a class=&#34;anchor&#34; href=&#34;#%e5%90%8d%e8%a9%9e--%e3%81%8b--%e5%90%8d%e8%a9%9e&#34;&gt;#&lt;/a&gt;&lt;/h2&gt;&#xD;&#xA;&lt;/blockquote&gt;&lt;blockquote class=&#39;book-hint &#39;&gt;&#xD;&#xA;&lt;p&gt;&lt;span class=&#34;book-katex optional&#34; &gt;\( いつが\overset{ひま}{暇}ですか。 \)&lt;/span&gt;（什麼時候有空呢？）&lt;br&gt;&#xA;&lt;span class=&#34;book-katex optional&#34; &gt;\( \overset{どようび}{土曜日}\textcolor{blue}{か}\overset{にちようび}{日曜日}です。 \)&lt;/span&gt;（星期六或是星期日。）&lt;/p&gt;</description>
			</item>
			<item>
				<title>助詞＋動詞</title>
				<link>https://nihongo.ray247k.com/docs/%E5%9F%BA%E7%A4%8E%E6%96%87%E6%B3%95/%E5%8A%A9%E8%A9%9E/%E5%8A%A9%E8%A9%9E%E5%8B%95%E8%A9%9E/</link>
				<pubDate>Mon, 01 Jan 0001 00:00:00 +0000</pubDate>
				<guid>https://nihongo.ray247k.com/docs/%E5%9F%BA%E7%A4%8E%E6%96%87%E6%B3%95/%E5%8A%A9%E8%A9%9E/%E5%8A%A9%E8%A9%9E%E5%8B%95%E8%A9%9E/</guid>
				<description>&lt;ul&gt;&#xA;&lt;li&gt;了解助詞「も」「に」「で」「と」的意思&lt;/li&gt;&#xA;&lt;li&gt;了解助詞「も」「に」「で」「と」的基本用法&lt;/li&gt;&#xA;&lt;/ul&gt;&#xA;&lt;h1 id=&#34;も也&#34;&gt;も(也)&lt;a class=&#34;anchor&#34; href=&#34;#%e3%82%82%e4%b9%9f&#34;&gt;#&lt;/a&gt;&lt;/h1&gt;&#xD;&#xA;&lt;p&gt;很常見到，用於表示兩者相等&lt;/p&gt;&#xA;&lt;blockquote class=&#39;book-hint &#39;&gt;&#xD;&#xA;&lt;h4 id=&#34;名詞--も--名詞形容詞動詞--です&#34;&gt;名詞 + も + 名詞／形容詞／動詞 + です&lt;a class=&#34;anchor&#34; href=&#34;#%e5%90%8d%e8%a9%9e--%e3%82%82--%e5%90%8d%e8%a9%9e%e5%bd%a2%e5%ae%b9%e8%a9%9e%e5%8b%95%e8%a9%9e--%e3%81%a7%e3%81%99&#34;&gt;#&lt;/a&gt;&lt;/h4&gt;&#xD;&#xA;&lt;/blockquote&gt;&lt;blockquote class=&#39;book-hint &#39;&gt;&#xD;&#xA;&lt;p&gt;&lt;span class=&#34;book-katex optional&#34; &gt;\( \overset{すずき}{鈴木}さんは\overset{だいがくせい}{大学生}です。私\textcolor{blue}{も}\overset{だいがくせい}{大学生}です。 \)&lt;/span&gt;&lt;link rel=&#34;stylesheet&#34; href=&#34;https://nihongo.ray247k.com/katex/katex.min.css&#34; /&gt;&lt;script defer src=&#34;https://nihongo.ray247k.com/katex/katex.min.js&#34;&gt;&lt;/script&gt;&lt;script defer src=&#34;https://nihongo.ray247k.com/katex/auto-render.min.js&#34; onload=&#34;renderMathInElement(document.body, {&amp;#34;delimiters&amp;#34;:[{&amp;#34;left&amp;#34;:&amp;#34;$$&amp;#34;,&amp;#34;right&amp;#34;:&amp;#34;$$&amp;#34;,&amp;#34;display&amp;#34;:true},{&amp;#34;left&amp;#34;:&amp;#34;\\(&amp;#34;,&amp;#34;right&amp;#34;:&amp;#34;\\)&amp;#34;,&amp;#34;display&amp;#34;:false},{&amp;#34;left&amp;#34;:&amp;#34;\\[&amp;#34;,&amp;#34;right&amp;#34;:&amp;#34;\\]&amp;#34;,&amp;#34;display&amp;#34;:true}]});&#34;&gt;&lt;/script&gt;&lt;br&gt;&#xA;（鈴木先生是大學生，我也是大學生）&lt;/p&gt;&#xA;&lt;/blockquote&gt;&lt;blockquote class=&#39;book-hint &#39;&gt;&#xD;&#xA;&lt;p&gt;&lt;span class=&#34;book-katex optional&#34; &gt;\( ピザを\overset{か}{買}いました。パスタ\textcolor{blue}{も}かいました。 \)&lt;/span&gt;&lt;br&gt;&#xA;（買了披薩，也買了義大利麵）&lt;/p&gt;&#xA;&lt;/blockquote&gt;&lt;h1 id=&#34;に表示目的地&#34;&gt;に(表示目的地)&lt;a class=&#34;anchor&#34; href=&#34;#%e3%81%ab%e8%a1%a8%e7%a4%ba%e7%9b%ae%e7%9a%84%e5%9c%b0&#34;&gt;#&lt;/a&gt;&lt;/h1&gt;&#xD;&#xA;&lt;p&gt;後面主要接續和「移動」有關的動詞，用來表示「移動的目的地」&lt;/p&gt;&#xA;&lt;blockquote class=&#39;book-hint &#39;&gt;&#xD;&#xA;&lt;h4 id=&#34;名詞は場所地點に行いきます来きます帰かえります&#34;&gt;名詞は場所/地點+に+行(い)きます/来(き)ます/帰(かえ)ります&lt;a class=&#34;anchor&#34; href=&#34;#%e5%90%8d%e8%a9%9e%e3%81%af%e5%a0%b4%e6%89%80%e5%9c%b0%e9%bb%9e%e3%81%ab%e8%a1%8c%e3%81%84%e3%81%8d%e3%81%be%e3%81%99%e6%9d%a5%e3%81%8d%e3%81%be%e3%81%99%e5%b8%b0%e3%81%8b%e3%81%88%e3%82%8a%e3%81%be%e3%81%99&#34;&gt;#&lt;/a&gt;&lt;/h4&gt;&#xD;&#xA;&lt;/blockquote&gt;&lt;p&gt;常見連接在：&lt;/p&gt;&#xA;&lt;ul&gt;&#xA;&lt;li&gt;&lt;span class=&#34;book-katex optional&#34; &gt;\( \overset{い}{行}く \)&lt;/span&gt; ：去&lt;/li&gt;&#xA;&lt;li&gt;&lt;span class=&#34;book-katex optional&#34; &gt;\( \overset{く}{来}る \)&lt;/span&gt;：來&lt;/li&gt;&#xA;&lt;li&gt;&lt;span class=&#34;book-katex optional&#34; &gt;\( \overset{かえ}{帰}る \)&lt;/span&gt;：回家&lt;/li&gt;&#xA;&lt;/ul&gt;&#xA;&lt;blockquote class=&#39;book-hint &#39;&gt;&#xD;&#xA;&lt;p&gt;&lt;span class=&#34;book-katex optional&#34; &gt;\( \overset{わたし}{私}は\overset{にほん}{日本}\textcolor{blue}{に}\overset{い}{行}きます。 \)&lt;/span&gt;（我去日本）&lt;/p&gt;&#xA;&lt;/blockquote&gt;&lt;blockquote class=&#39;book-hint &#39;&gt;&#xD;&#xA;&lt;p&gt;&lt;span class=&#34;book-katex optional&#34; &gt;\( お\overset{きゃく}{客}さんは\overset{うち}{家}\textcolor{blue}{に}\overset{き}{来}ました。 \)&lt;/span&gt;（客人來家裡了）&lt;/p&gt;&#xA;&lt;/blockquote&gt;&lt;blockquote class=&#39;book-hint &#39;&gt;&#xD;&#xA;&lt;p&gt;&lt;span class=&#34;book-katex optional&#34; &gt;\( \overset{おとうと}{弟}は\overset{いえ}{家}\textcolor{blue}{に}\overset{かえ}{帰}りました。 \)&lt;/span&gt;（弟弟已經回家了）&lt;/p&gt;</description>
			</item>
